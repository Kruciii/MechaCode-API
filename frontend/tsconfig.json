{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    // ZMIENIONE: Zamiast nodenext używamy standardu dla bundlerów (Vite)
    "module": "ESNext", 
    "moduleResolution": "bundler", 
    
    // DODANE: Żeby TS pozwolił na importowanie plików .ts/.tsx bez rozszerzeń
    "allowImportingTsExtensions": false, 
    "noEmit": true, // Vite zajmuje się budowaniem, nie TS

    "target": "esnext",
    "jsx": "react-jsx",
    
    // POZOSTAŁE OPCJE (zostaw jak masz lub dostosuj)
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    
    // To ustawienie często koliduje z Reactem, możesz je wyłączyć jeśli importy dalej wywalają błędy:
    "verbatimModuleSyntax": false 
  }
}